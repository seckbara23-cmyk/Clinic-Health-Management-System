# ============================================================
# CHMS Sénégal — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Payment feature flags ─────────────────────────────────────
# IMPORTANT: Keep false during the pilot program.
# Set to true ONLY when payment providers are fully configured
# and tested in sandbox, and after explicit go-live approval.
NEXT_PUBLIC_PAYMENTS_ENABLED=false
NEXT_PUBLIC_WAVE_ENABLED=false
NEXT_PUBLIC_ORANGE_MONEY_ENABLED=false

# ── Wave Business Checkout ────────────────────────────────────
# https://wave.com/en/business/api-docs/
# Leave empty during pilot. Never expose these client-side.
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
WAVE_BUSINESS_ID=
WAVE_CHECKOUT_SUCCESS_URL=https://your-app.vercel.app/billing?payment=success
WAVE_CHECKOUT_CANCEL_URL=https://your-app.vercel.app/billing?payment=cancelled

# ── Orange Money ─────────────────────────────────────────────
# Use sandbox until pilot ends. Never expose these client-side.
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_ID=
ORANGE_MONEY_WEBHOOK_SECRET=
ORANGE_MONEY_ENV=sandbox

# ── Rate limiting (Upstash Redis) ─────────────────────────────
# REQUIRED IN PRODUCTION — without these, rate limiting is disabled (fail-open).
# Get these from https://console.upstash.com → Create Database → REST API.
# Do NOT go live without setting these; unprotected routes can be abused.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: override default request limits per sliding 1-hour window
# RATE_LIMIT_CLINIC_REQUESTS=5
# RATE_LIMIT_SIGNUP=10
# RATE_LIMIT_CHANGE_PASSWORD=10

# ── Error monitoring (Sentry) ─────────────────────────────────
# Optional. Set to activate Sentry error reporting in production.
# Get the DSN from https://sentry.io → Your Project → Settings → Client Keys (DSN).
# Leave empty to use console-only logging (default, safe for local dev).
# NEXT_PUBLIC_ prefix is intentional: the DSN is safe to expose client-side.
# See src/lib/monitoring.ts for the integration hook.
NEXT_PUBLIC_SENTRY_DSN=
